classDiagram
direction TB
class Review {
  <<abstract>>
  Long id
  ReviewResult result
  LocalDateTime reviewedAt
}
class EnrollmentReview {
  int adjustedPremium
  double surchargeRate
}
class BenefitPaymentReview {
  Long assignedStaffId
}
class InsuranceApplication
class InsuranceEmployee
class Claim
class BenefitPayment
class AccidentHistory {
  <<embeddable>>
  int accidentCount
  int totalPaidAmount
}
Review <|-- EnrollmentReview
Review <|-- BenefitPaymentReview
EnrollmentReview --> InsuranceApplication : 심사 대상
EnrollmentReview --> InsuranceEmployee : 담당자
EnrollmentReview *-- AccidentHistory
BenefitPaymentReview --> Claim : 대상(의료+자동차)
BenefitPaymentReview ..> BenefitPayment : 지급 생성
